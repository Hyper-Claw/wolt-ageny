# --- Public domain (used by Caddy for automatic HTTPS when deploying) ---
# Point this domain's DNS A record at your server's IP first. Not needed for
# local testing.
DOMAIN=tips.yourchannel.com

# --- Receiving wallets (PUBLIC addresses only; never put a private key here) ---
ETH_ADDRESS=0xYourEthereumAddress
SOL_ADDRESS=YourSolanaAddress

# --- Accept USDC too (ERC-20 on Ethereum, SPL on Solana), same addresses ---
# Stablecoin = the EUR value of a tip doesn't swing. Set to false to disable.
USDC_ETH=true
USDC_SOL=true

# --- Secrets (pick long random strings) ---
# Put this in the OBS browser-source URLs: /overlay?key=<OVERLAY_KEY> and /goal?key=<OVERLAY_KEY>
OVERLAY_KEY=change-me-overlay
# Needed to fire test alerts and save settings from the /customize page
ADMIN_KEY=change-me-admin

# --- Fundraising goal (shown by the /goal widget; also editable in /customize) ---
GOAL_EUR=0
GOAL_TITLE=Stream Goal

# --- Optional tuning ---
PORT=3000
STREAMER_NAME=YourStreamName
# --- Networks watched for tips ---
# ETH is accepted on Ethereum, Base, Arbitrum, and Optimism; USDC on all of
# those plus Polygon; SOL/USDC on Solana. Her address is the same on every EVM
# chain, so donors can pay on whichever they like. Public RPCs below work out of
# the box; override any with your own (e.g. an Alchemy URL) for more headroom.
ETH_RPC=https://ethereum-rpc.publicnode.com
BASE_RPC=https://base-rpc.publicnode.com
ARBITRUM_RPC=https://arbitrum-one-rpc.publicnode.com
OPTIMISM_RPC=https://optimism-rpc.publicnode.com
POLYGON_RPC=https://polygon-bor-rpc.publicnode.com
SOL_RPC=https://api.mainnet-beta.solana.com
# Turn off any EVM chains you don't want, comma-separated, e.g. EVM_DISABLE=polygon,optimism
EVM_DISABLE=
PENDING_TTL_MIN=30
MIN_ETH=0.0005
MIN_SOL=0.005
MIN_USDC=0.5
# Optional: skip the CoinGecko price lookup with fixed EUR rates (offline / rate-limited hosts)
# PRICES_EUR=ethereum:3000,solana:150,usd-coin:0.92
